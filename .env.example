# Copy this to .env for local dev, or set these as variables in Railway's dashboard.

# Provided automatically by Railway when you add a Postgres database
DATABASE_URL=postgresql://user:password@host:port/database

# Generate a long random string for this — e.g. run: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-string

# Your frontend's URL (where index.html / join / propose are hosted)
FRONTEND_URL=https://your-frontend-domain.com

# If you want SSO across subdomains (e.g. theorder.com + wiki.theorder.com),
# set this to the shared parent domain. Leave blank otherwise.
COOKIE_DOMAIN=

# ---- Email (optional — leave blank to skip sending emails for now) ----
# Works with Gmail, Outlook, SendGrid, Mailgun, or any SMTP provider.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=The Royal Order <no-reply@yourdomain.com>

PORT=3000
